# =============================================================================
# CONFIGURACOES DE PRODUCAO - SISTEMA CONDOMINIAL
# =============================================================================
# IMPORTANTE: Este arquivo contem configuracoes seguras para producao.
# Copie para .env e ajuste os valores conforme seu ambiente.
# =============================================================================

# -----------------------------------------------------------------------------
# APLICACAO
# -----------------------------------------------------------------------------
APP_NAME="Plataforma Condominial"
APP_ENV=production
APP_KEY=                                    # Gere com: php artisan key:generate
APP_DEBUG=false                             # NUNCA true em producao!
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://seu-dominio.com.br          # Use HTTPS em producao

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                             # Menos verbose em producao

# -----------------------------------------------------------------------------
# BANCO DE DADOS
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=condominial_db
DB_USERNAME=condominial_user                # Usuario especifico, nunca root
DB_PASSWORD=                                # Senha forte aqui!

# -----------------------------------------------------------------------------
# SESSAO E CACHE
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120                        # 2 horas
SESSION_ENCRYPT=true                        # Criptografar sessoes
SESSION_SECURE_COOKIE=true                  # Cookies apenas via HTTPS

CACHE_STORE=redis                           # Redis recomendado para producao

# -----------------------------------------------------------------------------
# REDIS (Recomendado para producao)
# -----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# SANCTUM (Autenticacao API)
# -----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=seu-dominio.com.br,www.seu-dominio.com.br
SANCTUM_TOKEN_EXPIRATION=1440               # 24 horas (minutos)

# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------
FRONTEND_URL=https://seu-dominio.com.br

# -----------------------------------------------------------------------------
# MAIL (Configurar para reset de senha funcionar)
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.seu-provedor.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@seu-dominio.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# SEGURANCA ADICIONAL
# -----------------------------------------------------------------------------
# Forcas HTTPS
FORCE_HTTPS=true

# CORS mais restritivo
CORS_ALLOWED_ORIGINS=https://seu-dominio.com.br

# -----------------------------------------------------------------------------
# CHECKLIST DE SEGURANCA ANTES DE DEPLOY
# -----------------------------------------------------------------------------
# [ ] APP_DEBUG=false
# [ ] Senha forte no DB_PASSWORD
# [ ] Usuario especifico no DB_USERNAME (nao root)
# [ ] HTTPS configurado (APP_URL, FRONTEND_URL)
# [ ] SESSION_SECURE_COOKIE=true
# [ ] SANCTUM_STATEFUL_DOMAINS correto
# [ ] MAIL configurado para reset de senha
# [ ] Redis configurado para cache/sessoes
# [ ] Firewall configurado no servidor
# [ ] Certificado SSL valido
# [ ] Backups automaticos configurados
